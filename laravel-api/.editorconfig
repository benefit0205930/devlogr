root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[docker-compose.yml]
indent_size = 4

[*.php]
indent_size = 4
indent_style = space

[*.blade.php]
indent_size = 4
indent_style = space

[*.{js,jsx,ts,tsx,vue}]
indent_size = 2
indent_style = space

[*.{json,lock}]
indent_size = 4
indent_style = space

[composer.json]
indent_size = 4

[package.json]
indent_size = 2
